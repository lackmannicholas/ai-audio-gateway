# Copy to .env for local runs. Shell environment variables take precedence.

# Mock mode runs with no OpenAI key.
REALTIME_BACKEND=mock
THINKER_BACKEND=mock

# Real speech-to-speech mode.
# OPENAI_API_KEY=sk-...
# REALTIME_BACKEND=openai
# THINKER_BACKEND=openai
# OPENAI_BASE_URL=https://us.api.openai.com/v1
# OPENAI_REALTIME_URL=wss://us.api.openai.com/v1/realtime
# REALTIME_MODEL=gpt-realtime-2
# TRANSCRIPT_MODEL=gpt-4o-mini-transcribe
# OPENAI_SAFETY_IDENTIFIER=audio-gateway-poc

# Local server defaults.
# BUSINESS_ADDR=127.0.0.1:8002
# GATEWAY_HOST=127.0.0.1   # containers need 0.0.0.0 (compose sets it)
# GATEWAY_PORT=8001

# Bridge security defaults.
# BRIDGE_TOKEN=poc-dev-bridge-token
# BRIDGE_INSECURE=1

# Local VAD defaults. TEN VAD runs locally and gates audio before realtime.
# VAD__ENABLED=1
# VAD__THRESHOLD=0.6
# VAD__VAD_SAMPLE_RATE=16000
# VAD__VAD_FRAME_MS=32
# VAD__PRE_ROLL_MS=100
# Trailing-silence gate before an utterance is committed, in ~20ms input
# chunks: 15 = 300ms. This is a hard floor on response latency — the main
# latency/accuracy trade-off knob.
# VAD__HANGOVER_FRAMES=15

# Guardrails (run in the business plane). Comma-separated blocked topics; a
# transcript mentioning one gets the response cancelled across the wire. Empty
# disables. Default: weather.
# GUARDRAIL_BLOCKED_TOPICS=weather

# Mock-mode only: override the scripted caller utterance. Set it to mention a
# blocked topic to demo guardrails with no API key.
# MOCK_UTTERANCE=what's the weather today?
