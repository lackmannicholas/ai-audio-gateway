# Copy to .env for local runs. Shell environment variables take precedence.

# Mock mode runs with no OpenAI key.
REALTIME_BACKEND=mock
THINKER_BACKEND=mock

# Real speech-to-speech mode.
# OPENAI_API_KEY=sk-...
# REALTIME_BACKEND=openai
# THINKER_BACKEND=openai
# OPENAI_BASE_URL=https://us.api.openai.com/v1
# OPENAI_REALTIME_URL=wss://us.api.openai.com/v1/realtime
# REALTIME_MODEL=gpt-realtime-2
# TRANSCRIPT_MODEL=gpt-4o-mini-transcribe
# OPENAI_SAFETY_IDENTIFIER=audio-gateway-poc

# Local server defaults.
# BUSINESS_ADDR=127.0.0.1:8002
# GATEWAY_PORT=8001

# Bridge security defaults.
# BRIDGE_TOKEN=poc-dev-bridge-token
# BRIDGE_INSECURE=1
